// ─────────────────────────────────────────────────────────────────────────────
// Apply all patches
// ─────────────────────────────────────────────────────────────────────────────
const patches = [
  ['waterUnit state', P1_FIND, P1_REPLACE],
  ['addWater/removeWater + helpers', P2_FIND, P2_REPLACE],
  ['Water Tracker card (L/gal)', P3_FIND, P3_REPLACE],
  ['Food adjuster g/ml/cup', P4_FIND, P4_REPLACE],
  ['Remove Settings from bottom nav', P5_FIND, P5_REPLACE],
  ['Settings card on Dashboard', P6_FIND, P6_REPLACE],
];

let allPassed = true;
for (const [name, find, replace] of patches) {
  if (!code.includes(find)) {
    console.log(`✗ FAILED to find: ${name}`);
    allPassed = false;
  } else {
    code = code.replace(find, replace);
    console.log(`✓ Applied: ${name}`);
  }
}

if (allPassed) {
  fs.writeFileSync(FILE, code);
  console.log(`\n✅ All patches applied! ${FILE} updated (${code.split('\n').length} lines)`);
  console.log('\nCommit and push to deploy:');
  console.log('  git add src/App.jsx && git commit -m "feat: litres/gal water, food units, settings on dashboard" && git push');
} else {
  console.log('\n❌ Some patches failed. Your original is backed up at:', backup);
  console.log('Check that you are running this on the latest version from GitHub.');
  process.exit(1);
}
