#!/usr/bin/env node
/**
 * Run from your Daily-Tracker- project root:
 *   node patch_v2.js
 * 
 * Changes applied:
 *  1. Water tracker: switches to litres/gallons display with L/gal toggle
 *  2. Macro food adjuster: adds g / ml / cup unit options
 *  3. Bottom nav: removes Settings (6 tabs instead of 7)
 *  4. Dashboard: adds Settings quick-access card
 */

const fs = require('fs');
const FILE = 'src/App.jsx';

if (!fs.existsSync(FILE)) {
  console.error(`Error: ${FILE} not found. Run from project root.`);
  process.exit(1);
}

let code = fs.readFileSync(FILE, 'utf8');
const backup = FILE + '.backup_' + Date.now();
fs.writeFileSync(backup, code);
console.log(`✓ Backed up to ${backup}`);

// ─────────────────────────────────────────────────────────────────────────────
// PATCH 1: Add waterUnit state after waterCups state
// ─────────────────────────────────────────────────────────────────────────────
const P1_FIND = `  const [waterCups, setWaterCups] = useState(() => {
    try { const w = JSON.parse(localStorage.getItem("dat-water") || "{}"); return w[getLocalDateStr()] || 0; } catch { return 0; }
  });`;

const P1_REPLACE = `  const [waterCups, setWaterCups] = useState(() => {
    try { const w = JSON.parse(localStorage.getItem("dat-water") || "{}"); return w[getLocalDateStr()] || 0; } catch { return 0; }
  });
  const [waterUnit, setWaterUnit] = useState(() => localStorage.getItem("dat-water-unit") || "L");`;

// ─────────────────────────────────────────────────────────────────────────────
// PATCH 2: Replace addWater/removeWater with unit-aware versions + helpers
// ─────────────────────────────────────────────────────────────────────────────
const P2_FIND = `  function addWater() {
    const next = Math.min(waterCups + 1, 20);
    setWaterCups(next);
    const all = JSON.parse(localStorage.getItem("dat-water") || "{}");
    all[getLocalDateStr()] = next;
    localStorage.setItem("dat-water", JSON.stringify(all));
    haptic("light");
  }
  function removeWater() {
    const next = Math.max(waterCups - 1, 0);
    setWaterCups(next);
    const all = JSON.parse(localStorage.getItem("dat-water") || "{}");
    all[getLocalDateStr()] = next;
    localStorage.setItem("dat-water", JSON.stringify(all));
  }`;

const P2_REPLACE = `  // Water unit helpers — internal unit is "cups" (250ml each), displayed as L or gal
  function waterDisplayVal() {
    const litres = waterCups * 0.25;
    if (waterUnit === "gal") return parseFloat((litres / 3.78541).toFixed(2));
    return parseFloat(litres.toFixed(2));
  }
  function waterUnitGoal() {
    const litres = S_WATER_GOAL * 0.25;
    if (waterUnit === "gal") return parseFloat((litres / 3.78541).toFixed(2));
    return parseFloat(litres.toFixed(2));
  }

  function addWater() {
    const next = Math.min(waterCups + 1, 40);
    setWaterCups(next);
    const all = JSON.parse(localStorage.getItem("dat-water") || "{}");
    all[getLocalDateStr()] = next;
    localStorage.setItem("dat-water", JSON.stringify(all));
    haptic("light");
  }
  function removeWater() {
    const next = Math.max(waterCups - 1, 0);
    setWaterCups(next);
    const all = JSON.parse(localStorage.getItem("dat-water") || "{}");
    all[getLocalDateStr()] = next;
    localStorage.setItem("dat-water", JSON.stringify(all));
  }`;

